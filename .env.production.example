NODE_ENV=production
APP_VERSION=0.2.0-rc.7
API_DOCS_ENABLED=false
OPEN_LOGISTIRIO_API_IMAGE=ghcr.io/abramis/openlogistirio-api
OPEN_LOGISTIRIO_WEB_IMAGE=ghcr.io/abramis/openlogistirio-web
MYSQL_DATABASE=open_logistirio
MYSQL_USER=openlog
MYSQL_PASSWORD=replace-with-a-long-unique-password
MYSQL_ROOT_PASSWORD=replace-with-another-long-unique-password
REDIS_PASSWORD=replace-with-a-long-unique-password

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-random-characters
INITIAL_SETUP_TOKEN=replace-with-at-least-32-random-characters
FRONTEND_ORIGIN=https://accounting.example.gr
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=8088
BACKUP_DIR=/workspace/backups
SUPPORTING_DOCUMENTS_DIR=/workspace/storage/supporting-documents
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_AGE_HOURS=36
# Used only by the isolated, non-network-published restore-drill database.
RESTORE_DRILL_MYSQL_ROOT_PASSWORD=replace-with-a-long-restore-drill-only-password
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
TRUST_PROXY=true

# Keep this false until an accountant explicitly authorizes a production AADE send.
AADE_MYDATA_ENV=test
AADE_MYDATA_PRODUCTION_READ_ENABLED=false
AADE_MYDATA_PRODUCTION_ENABLED=false
MYDATA_SCHEDULED_SYNC_ENABLED=false
MYDATA_SCHEDULED_SYNC_CRON=0 2 * * *
MYDATA_SCHEDULED_SYNC_MAX_PAGES=10
