generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ACCOUNTING_OFFICE_ADMIN
  ACCOUNTANT
  ASSISTANT
  CLIENT_READONLY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum DocumentType {
  SALES_INVOICE
  PURCHASE_INVOICE
  CREDIT_NOTE
  RETAIL_RECEIPT
}

enum MyDataStatus {
  DRAFT
  READY_TO_SEND
  SENT
  FAILED
  CANCELLED
}

enum TransmissionStatus {
  PREPARED
  SENT
  FAILED
}

enum ClientEntityType {
  COMPANY
  FREELANCER
  SOLE_PROPRIETOR
  NON_PROFIT
  OTHER
}

enum MyDataTransmissionMode {
  ACCOUNTING_OFFICE_AUTHORIZED
  OWN_API_CREDENTIALS_ENV_REF
  MANUAL_UPLOAD
  NOT_CONFIGURED
}

enum ObligationType {
  VAT_RETURN
  MYDATA_REVIEW
  WITHHOLDING_TAX
  INCOME_TAX_PREP
  PAYROLL_REVIEW
  CUSTOM
}

enum ObligationStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  READY_TO_SUBMIT
  SUBMITTED
  CANCELLED
}

enum ObligationRecurrence {
  NONE
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum FixedAssetCategory {
  EQUIPMENT
  SOFTWARE
  VEHICLE
  FURNITURE
  BUILDING
  OTHER
}

enum FixedAssetStatus {
  ACTIVE
  SOLD
  SCRAPPED
}

enum CounterpartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum ImportBatchType {
  DOCUMENTS_CSV
}

enum ImportBatchStatus {
  PREVIEW
  COMPLETED
  FAILED
  ROLLED_BACK
}

enum DeclarationWorkpaperType {
  VAT_RETURN
  MYDATA_RECONCILIATION
  WITHHOLDING_TAX
  INCOME_TAX_PREP
  PAYROLL_REVIEW
}

enum DeclarationWorkpaperStatus {
  DRAFT
  READY
  APPROVED
  SUBMITTED
  ARCHIVED
}

enum DeclarationWorkpaperPeriodKind {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum PeriodCloseKind {
  MONTHLY
  QUARTERLY
}

enum PeriodCloseReviewStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  REJECTED
}

enum ChartAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalEntrySource {
  MANUAL
  DOCUMENT
  FIXED_ASSET
  OPENING
  CLOSING
  ADJUSTMENT
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum MyDataSyncSource {
  REQUEST_DOCS
  REQUEST_TRANSMITTED_DOCS
}

enum MyDataSyncRunStatus {
  COMPLETED
  FAILED
}

enum MyDataReconciliationStatus {
  MATCHED
  MISSING_INTERNAL
  AMOUNT_MISMATCH
  DATE_MISMATCH
  TYPE_MISMATCH
  COUNTERPARTY_MISMATCH
}

enum MyDataSnapshotReviewStatus {
  PENDING
  RESOLVED
  IGNORED
}

enum ExpenseClassificationApprovalStatus {
  NOT_REQUESTED
  PENDING
  APPROVED
  REJECTED
  CONSUMED
}

enum DispatchNoteStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum DeliveryOutcome {
  FULL
  PARTIAL
  NONE
}

enum DispatchEventType {
  CREATED
  UPDATED
  ISSUED
  DELIVERY_COMPLETED
  DELIVERY_PARTIAL
  DELIVERY_REJECTED
  CANCELLED
}

enum StockMovementKind {
  ADJUSTMENT
  DISPATCH_OUT
  DELIVERY_IN
  CANCEL_OUT_REVERSAL
  CANCEL_IN_REVERSAL
}

model AccountingOffice {
  id        String   @id @default(cuid())
  name      String
  vatNumber String?  @db.VarChar(9)
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  clientCompanies       ClientCompany[]
  documents             Document[]
  fixedAssets           FixedAsset[]
  clientSetupItems      ClientSetupItem[]
  obligations           OfficeObligation[]
  taxCalendarRules      TaxCalendarRule[]
  taxCalendarOverrides  TaxCalendarOverride[]
  counterparties        Counterparty[]
  importBatches         ImportBatch[]
  declarationWorkpapers DeclarationWorkpaper[]
  chartAccounts         ChartAccount[]
  documentPostingRules  DocumentPostingRule[]
  accountingPeriods     AccountingPeriod[]
  journalEntries        JournalEntry[]
  auditLogs             AuditLog[]
  myDataSyncRuns        MyDataSyncRun[]
  myDataSnapshots       MyDataSnapshot[]
  periodCloseReviews    PeriodCloseReview[]
  supportingDocuments  SupportingDocument[]
  inventoryItems       InventoryItem[]
  warehouses           Warehouse[]
  vehicles             Vehicle[]
  dispatchNotes        DispatchNote[]
  stockMovements       StockMovement[]
  dispatchReceipts     DispatchDeliveryReceipt[]
  dispatchEvents       DispatchLifecycleEvent[]
}

model User {
  id                  String    @id @default(cuid())
  accountingOfficeId  String
  email               String    @unique
  passwordHash        String
  fullName            String
  role                UserRole
  disabledAt          DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  passwordChangedAt   DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accountingOffice              AccountingOffice       @relation(fields: [accountingOfficeId], references: [id])
  auditLogs                     AuditLog[]
  assignedObligations           OfficeObligation[]     @relation("AssignedObligations")
  refreshTokens                 RefreshToken[]
  passwordResetTokens           PasswordResetToken[]
  preparedPeriodCloseReviews    PeriodCloseReview[]    @relation("PeriodClosePreparedBy")
  approvedPeriodCloseReviews    PeriodCloseReview[]    @relation("PeriodCloseApprovedBy")
  approvedDeclarationWorkpapers DeclarationWorkpaper[] @relation("DeclarationWorkpaperApprovedBy")
  reviewedMyDataSnapshots         MyDataSnapshot[]      @relation("MyDataSnapshotReviewedBy")
  approvedExpenseClassifications Document[]            @relation("ExpenseClassificationApprovedBy")

  @@index([accountingOfficeId])
  @@index([disabledAt])
  @@index([lockedUntil])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  jwtId             String    @unique @db.VarChar(80)
  tokenHash         String    @unique @db.VarChar(128)
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique @db.VarChar(128)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, usedAt, expiresAt])
}

model ClientCompany {
  id                  String                 @id @default(cuid())
  accountingOfficeId  String
  legalName           String
  tradeName           String?
  entityType          ClientEntityType       @default(COMPANY)
  professionLabel     String?
  vatNumber           String                 @db.VarChar(9)
  taxOffice           String?
  activityCodes       Json?
  address             String?
  email               String?
  phone               String?
  vatRegime           String?
  accountingCategory  String?
  myDataMode          MyDataTransmissionMode @default(ACCOUNTING_OFFICE_AUTHORIZED)
  myDataAuthorized    Boolean                @default(false)
  myDataCredentialRef String?
  fiscalYearStart     Int                    @default(1)
  fiscalYearEnd       Int                    @default(12)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  deletedAt           DateTime?

  accountingOffice      AccountingOffice       @relation(fields: [accountingOfficeId], references: [id])
  documents             Document[]
  fixedAssets           FixedAsset[]
  setupItems            ClientSetupItem[]
  obligations           OfficeObligation[]
  counterparties        Counterparty[]
  importBatches         ImportBatch[]
  declarationWorkpapers DeclarationWorkpaper[]
  chartAccounts         ChartAccount[]
  documentPostingRules  DocumentPostingRule[]
  accountingPeriods     AccountingPeriod[]
  journalEntries        JournalEntry[]
  myDataSyncRuns        MyDataSyncRun[]
  myDataSnapshots       MyDataSnapshot[]
  periodCloseReviews    PeriodCloseReview[]
  supportingDocuments  SupportingDocument[]
  inventoryItems       InventoryItem[]
  warehouses           Warehouse[]
  vehicles             Vehicle[]
  dispatchNotes        DispatchNote[]
  stockMovements       StockMovement[]
  dispatchReceipts     DispatchDeliveryReceipt[]
  dispatchEvents       DispatchLifecycleEvent[]

  @@unique([accountingOfficeId, vatNumber])
  @@index([accountingOfficeId, deletedAt])
}

model ChartAccount {
  id                 String           @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  code               String           @db.VarChar(40)
  name               String
  type               ChartAccountType
  normalBalance      NormalBalance
  parentId           String?
  isControl          Boolean          @default(false)
  isActive           Boolean          @default(true)
  taxCategory        String?          @db.VarChar(80)
  myDataCategory     String?          @db.VarChar(80)
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  accountingOffice AccountingOffice   @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany      @relation(fields: [clientCompanyId], references: [id])
  parent           ChartAccount?      @relation("ChartAccountTree", fields: [parentId], references: [id])
  children         ChartAccount[]     @relation("ChartAccountTree")
  journalLines     JournalEntryLine[]

  @@unique([clientCompanyId, code])
  @@index([accountingOfficeId, clientCompanyId, type])
  @@index([parentId])
}

model DocumentPostingRule {
  id                      String         @id @default(cuid())
  accountingOfficeId      String
  clientCompanyId         String
  code                    String         @db.VarChar(80)
  name                    String
  documentType            DocumentType?
  movementCode            String?        @db.VarChar(80)
  journalCode             String?        @db.VarChar(80)
  counterpartyAccountCode String         @db.VarChar(40)
  counterpartySide        NormalBalance
  netAccountCode          String         @db.VarChar(40)
  netSide                 NormalBalance
  vatAccountCode          String?        @db.VarChar(40)
  vatSide                 NormalBalance?
  isActive                Boolean        @default(true)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])

  @@unique([clientCompanyId, code], map: "DocPostingRule_client_code_key")
  @@index([accountingOfficeId, clientCompanyId, isActive], map: "DocPostingRule_office_client_active_idx")
  @@index([clientCompanyId, movementCode], map: "DocPostingRule_client_movement_idx")
  @@index([clientCompanyId, documentType], map: "DocPostingRule_client_doc_type_idx")
}

model AccountingPeriod {
  id                 String                 @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  fiscalYear         Int
  periodMonth        Int
  startsAt           DateTime
  endsAt             DateTime
  status             AccountingPeriodStatus @default(OPEN)
  closedAt           DateTime?
  lockedAt           DateTime?
  notes              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])

  @@unique([clientCompanyId, fiscalYear, periodMonth])
  @@index([accountingOfficeId, clientCompanyId, status])
}

model JournalEntry {
  id                 String             @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  entryNumber        String             @db.VarChar(80)
  entryDate          DateTime
  fiscalYear         Int
  periodMonth        Int
  source             JournalEntrySource
  status             JournalEntryStatus @default(POSTED)
  description        String
  reference          String?
  postedAt           DateTime?
  voidedAt           DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  accountingOffice  AccountingOffice                       @relation(fields: [accountingOfficeId], references: [id])
  clientCompany     ClientCompany                          @relation(fields: [clientCompanyId], references: [id])
  lines             JournalEntryLine[]
  documentLinks     DocumentAccountingLink[]
  depreciationLinks FixedAssetDepreciationAccountingLink[]

  @@unique([clientCompanyId, entryNumber])
  @@index([accountingOfficeId, clientCompanyId, entryDate])
  @@index([clientCompanyId, fiscalYear, periodMonth, status])
}

model JournalEntryLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  lineNumber     Int
  description    String?
  debit          Decimal  @default(0) @db.Decimal(12, 2)
  credit         Decimal  @default(0) @db.Decimal(12, 2)
  taxCode        String?  @db.VarChar(40)
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])
  account      ChartAccount @relation(fields: [accountId], references: [id])

  @@unique([journalEntryId, lineNumber])
  @@index([accountId])
}

model DocumentAccountingLink {
  id             String   @id @default(cuid())
  documentId     String
  journalEntryId String
  createdAt      DateTime @default(now())

  document     Document     @relation(fields: [documentId], references: [id])
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])

  @@unique([documentId])
  @@unique([journalEntryId])
}

model ClientSetupItem {
  id                 String   @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  kind               String   @db.VarChar(80)
  code               String   @db.VarChar(80)
  name               String
  description        String?
  metadata           Json?
  sourceTemplate     String?  @db.VarChar(80)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])

  @@unique([clientCompanyId, kind, code], map: "ClientSetupItem_client_kind_code_key")
  @@index([accountingOfficeId, clientCompanyId, kind], map: "ClientSetupItem_office_client_kind_idx")
}

model Counterparty {
  id                 String           @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  type               CounterpartyType
  name               String
  vatNumber          String?          @db.VarChar(20)
  country            String           @default("GR") @db.VarChar(2)
  taxOffice          String?
  address            String?
  email              String?
  phone              String?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  dispatchNotes    DispatchNote[]

  @@index([accountingOfficeId, clientCompanyId, type])
  @@index([clientCompanyId, vatNumber])
}

model InventoryItem {
  id                 String   @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  code               String   @db.VarChar(50)
  name               String   @db.VarChar(200)
  description        String?
  measurementUnit    Int      @default(1)
  trackInventory     Boolean  @default(true)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  balances         WarehouseStock[]
  dispatchLines    DispatchNoteLine[]
  stockMovements   StockMovement[]

  @@unique([clientCompanyId, code], map: "InventoryItem_client_code_key")
  @@index([accountingOfficeId, clientCompanyId, isActive], map: "InventoryItem_office_client_active_idx")
}

model Warehouse {
  id                 String   @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  code               String   @db.VarChar(40)
  name               String   @db.VarChar(200)
  address             String?
  branchNumber        Int?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  accountingOffice     AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany        ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  balances             WarehouseStock[]
  outgoingDispatches   DispatchNote[]   @relation("DispatchLoadingWarehouse")
  incomingDispatches   DispatchNote[]   @relation("DispatchDeliveryWarehouse")
  stockMovements       StockMovement[]

  @@unique([clientCompanyId, code], map: "Warehouse_client_code_key")
  @@index([accountingOfficeId, clientCompanyId, isActive], map: "Warehouse_office_client_active_idx")
}

model Vehicle {
  id                 String   @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  registrationNumber String   @db.VarChar(40)
  description        String?
  vehicleType        String?  @db.VarChar(80)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  dispatchNotes    DispatchNote[]

  @@unique([clientCompanyId, registrationNumber], map: "Vehicle_client_registration_key")
  @@index([accountingOfficeId, clientCompanyId, isActive], map: "Vehicle_office_client_active_idx")
}

model WarehouseStock {
  id          String   @id @default(cuid())
  warehouseId String
  itemId      String
  quantity    Decimal  @default(0) @db.Decimal(14, 3)
  updatedAt   DateTime @updatedAt

  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  item      InventoryItem @relation(fields: [itemId], references: [id])

  @@unique([warehouseId, itemId], map: "WarehouseStock_warehouse_item_key")
  @@index([itemId], map: "WarehouseStock_item_idx")
}

model DispatchNote {
  id                    String             @id @default(cuid())
  accountingOfficeId    String
  clientCompanyId       String
  series                String             @db.VarChar(40)
  number                String             @db.VarChar(80)
  issueDate             DateTime
  plannedDispatchAt     DateTime
  status                DispatchNoteStatus @default(DRAFT)
  movePurpose           Int
  otherMovePurposeTitle String?            @db.VarChar(150)
  counterpartyId        String?
  recipientName         String?
  recipientVatNumber    String?            @db.VarChar(20)
  loadingWarehouseId    String
  deliveryWarehouseId   String?
  vehicleId             String?
  vehicleNumber         String?            @db.VarChar(150)
  loadingAddress        String
  deliveryAddress       String
  notes                 String?
  issuedAt              DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  accountingOffice  AccountingOffice  @relation(fields: [accountingOfficeId], references: [id])
  clientCompany     ClientCompany     @relation(fields: [clientCompanyId], references: [id])
  counterparty      Counterparty?     @relation(fields: [counterpartyId], references: [id])
  loadingWarehouse  Warehouse         @relation("DispatchLoadingWarehouse", fields: [loadingWarehouseId], references: [id])
  deliveryWarehouse Warehouse?        @relation("DispatchDeliveryWarehouse", fields: [deliveryWarehouseId], references: [id])
  vehicle           Vehicle?          @relation(fields: [vehicleId], references: [id])
  lines             DispatchNoteLine[]
  stockMovements    StockMovement[]
  deliveryReceipt   DispatchDeliveryReceipt?
  lifecycleEvents   DispatchLifecycleEvent[]

  @@unique([clientCompanyId, series, number], map: "DispatchNote_client_series_number_key")
  @@index([accountingOfficeId, clientCompanyId, status, plannedDispatchAt], map: "DispatchNote_office_client_status_date_idx")
  @@index([counterpartyId], map: "DispatchNote_counterparty_idx")
  @@index([vehicleId], map: "DispatchNote_vehicle_idx")
}

model DispatchNoteLine {
  id                        String   @id @default(cuid())
  dispatchNoteId            String
  itemId                    String
  lineNumber                Int
  itemCode                  String   @db.VarChar(50)
  description               String   @db.VarChar(300)
  quantity                  Decimal  @db.Decimal(14, 3)
  measurementUnit           Int
  movePurposeLine           Int?
  otherMovePurposeLineTitle String?  @db.VarChar(150)
  createdAt                 DateTime @default(now())

  dispatchNote  DispatchNote    @relation(fields: [dispatchNoteId], references: [id], onDelete: Cascade)
  item          InventoryItem   @relation(fields: [itemId], references: [id])
  stockMovements StockMovement[]
  receiptLine    DispatchDeliveryReceiptLine?

  @@unique([dispatchNoteId, lineNumber], map: "DispatchNoteLine_note_line_key")
  @@index([itemId], map: "DispatchNoteLine_item_idx")
}

model StockMovement {
  id                 String            @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  warehouseId        String
  itemId             String
  dispatchNoteId     String?
  dispatchNoteLineId String?
  kind               StockMovementKind
  quantity           Decimal           @db.Decimal(14, 3)
  occurredAt         DateTime
  createdAt          DateTime          @default(now())

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  warehouse        Warehouse        @relation(fields: [warehouseId], references: [id])
  item             InventoryItem    @relation(fields: [itemId], references: [id])
  dispatchNote     DispatchNote?     @relation(fields: [dispatchNoteId], references: [id])
  dispatchNoteLine DispatchNoteLine? @relation(fields: [dispatchNoteLineId], references: [id])

  @@unique([dispatchNoteLineId, warehouseId, kind], map: "StockMovement_line_warehouse_kind_key")
  @@index([accountingOfficeId, clientCompanyId, occurredAt], map: "StockMovement_office_client_date_idx")
  @@index([warehouseId, itemId, occurredAt], map: "StockMovement_warehouse_item_date_idx")
}

model DispatchDeliveryReceipt {
  id                        String          @id @default(cuid())
  accountingOfficeId        String
  clientCompanyId           String
  dispatchNoteId            String          @unique
  outcome                   DeliveryOutcome
  deliveredWithoutRecipient Boolean         @default(false)
  receivedAt                DateTime
  notes                     String?
  createdAt                 DateTime         @default(now())

  accountingOffice AccountingOffice             @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany                @relation(fields: [clientCompanyId], references: [id])
  dispatchNote     DispatchNote                 @relation(fields: [dispatchNoteId], references: [id])
  lines            DispatchDeliveryReceiptLine[]

  @@index([accountingOfficeId, clientCompanyId, receivedAt], map: "DispatchReceipt_office_client_date_idx")
}

model DispatchDeliveryReceiptLine {
  id                 String   @id @default(cuid())
  receiptId          String
  dispatchNoteLineId String   @unique
  orderedQuantity    Decimal  @db.Decimal(14, 3)
  acceptedQuantity   Decimal  @db.Decimal(14, 3)
  rejectedQuantity   Decimal  @db.Decimal(14, 3)
  missingQuantity    Decimal  @db.Decimal(14, 3)
  qualityNotes       String?
  createdAt          DateTime @default(now())

  receipt          DispatchDeliveryReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  dispatchNoteLine DispatchNoteLine         @relation(fields: [dispatchNoteLineId], references: [id])

  @@index([receiptId], map: "DispatchReceiptLine_receipt_idx")
}

model DispatchLifecycleEvent {
  id                 String            @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  dispatchNoteId     String
  eventType          DispatchEventType
  eventAt            DateTime
  details            Json?
  createdAt          DateTime          @default(now())

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  dispatchNote     DispatchNote     @relation(fields: [dispatchNoteId], references: [id], onDelete: Cascade)

  @@index([accountingOfficeId, clientCompanyId, eventAt], map: "DispatchEvent_office_client_date_idx")
  @@index([dispatchNoteId, eventAt], map: "DispatchEvent_note_date_idx")
}

model SupportingDocument {
  id                 String   @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  originalName       String   @db.VarChar(255)
  storageKey         String   @unique @db.VarChar(255)
  contentType        String   @db.VarChar(120)
  sizeBytes          Int
  createdAt          DateTime @default(now())

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])

  @@index([accountingOfficeId, clientCompanyId, createdAt])
}

model ImportBatch {
  id                 String            @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  type               ImportBatchType
  status             ImportBatchStatus
  fileName           String?
  totalRows          Int               @default(0)
  successfulRows     Int               @default(0)
  failedRows         Int               @default(0)
  errorReport        Json?
  rolledBackAt       DateTime?
  createdAt          DateTime          @default(now())

