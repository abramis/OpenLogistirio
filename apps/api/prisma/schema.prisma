  series                   String?
  documentNumber           String
  issueDate                DateTime
  counterpartyName         String?
  counterpartyVatNumber    String?      @db.VarChar(20)
  movementCode             String?      @db.VarChar(80)
  journalCode              String?      @db.VarChar(80)
  netAmount                Decimal      @db.Decimal(12, 2)
  vatAmount                Decimal      @db.Decimal(12, 2)
  totalAmount              Decimal      @db.Decimal(12, 2)
  vatCategory              String
  paymentMethodType        Int          @default(3)
  vatExemptionCategory     Int?
  correlatedInvoiceMark    String?      @db.VarChar(40)
  withheldAmount           Decimal      @default(0) @db.Decimal(12, 2)
  withheldCategory         Int?
  feesAmount               Decimal      @default(0) @db.Decimal(12, 2)
  feesCategory             Int?
  stampDutyAmount          Decimal      @default(0) @db.Decimal(12, 2)
  stampDutyCategory        Int?
  otherTaxesAmount         Decimal      @default(0) @db.Decimal(12, 2)
  otherTaxesCategory       Int?
  deductionsAmount         Decimal      @default(0) @db.Decimal(12, 2)
  importBatchId            String?
  replacesDocumentId       String?
  correctsDocumentId       String?
  myDataStatus             MyDataStatus @default(DRAFT)
  myDataMark               String?
  myDataUid                String?
  myDataQrUrl              String?
  myDataClassificationMark String?      @db.VarChar(40)
  myDataCancellationMark   String?      @db.VarChar(40)
  myDataCancelledAt        DateTime?
  myDataXmlPreview         String?      @db.LongText
  classificationStatus     String?
  expenseClassificationApprovalStatus ExpenseClassificationApprovalStatus @default(NOT_REQUESTED)
  expenseClassificationApprovedById   String?
  expenseClassificationApprovedAt     DateTime?
  expenseClassificationApprovalNotes  String? @db.VarChar(500)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  deletedAt                DateTime?

  accountingOffice      AccountingOffice         @relation(fields: [accountingOfficeId], references: [id])
  clientCompany         ClientCompany            @relation(fields: [clientCompanyId], references: [id])
  importBatch           ImportBatch?             @relation(fields: [importBatchId], references: [id])
  transmissionAttempts  TransmissionAttempt[]
  lines                 DocumentLine[]
  payments              DocumentPayment[]
  accountingLinks       DocumentAccountingLink[]
  myDataSnapshotMatches MyDataSnapshot[]         @relation("MyDataSnapshotMatchedDocument")
  replacesDocument     Document?                 @relation("DocumentReplacement", fields: [replacesDocumentId], references: [id])
  replacedByDocuments  Document[]                @relation("DocumentReplacement")
  correctsDocument     Document?                 @relation("DocumentCorrection", fields: [correctsDocumentId], references: [id])
  correctedByDocuments Document[]                @relation("DocumentCorrection")
  expenseClassificationApprovedBy User?          @relation("ExpenseClassificationApprovedBy", fields: [expenseClassificationApprovedById], references: [id])

  @@index([accountingOfficeId, clientCompanyId, issueDate])
  @@index([accountingOfficeId, myDataStatus])
  @@unique([clientCompanyId, myDataMark], map: "Document_client_mydata_mark_key")
  @@unique([clientCompanyId, myDataUid], map: "Document_client_mydata_uid_key")
  @@index([myDataClassificationMark])
  @@index([myDataCancellationMark])
  @@index([accountingOfficeId, expenseClassificationApprovalStatus])
  @@index([expenseClassificationApprovedById])
  @@index([clientCompanyId, movementCode, issueDate])
  @@index([clientCompanyId, journalCode, issueDate])
  @@index([replacesDocumentId])
  @@index([correctsDocumentId])
  @@index([importBatchId])
}

