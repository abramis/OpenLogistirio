model MyDataSnapshot {
  id                    String                     @id @default(cuid())
  accountingOfficeId    String
  clientCompanyId       String
  syncRunId             String
  matchedDocumentId     String?
  source                MyDataSyncSource
  reconciliationStatus  MyDataReconciliationStatus
  reconciliationIssues  Json?
  reviewStatus           MyDataSnapshotReviewStatus @default(PENDING)
  reviewedById           String?
  reviewedAt             DateTime?
  reviewNotes            String?
  mark                  String                     @db.VarChar(40)
  uid                   String?                    @db.VarChar(120)
  qrUrl                 String?
  issuerVatNumber       String?                    @db.VarChar(20)
  counterpartyVatNumber String?                    @db.VarChar(20)
  invoiceType           String?                    @db.VarChar(20)
  series                String?                    @db.VarChar(80)
  documentNumber        String                     @db.VarChar(80)
  issueDate             DateTime?
  netAmount             Decimal?                   @db.Decimal(12, 2)
  vatAmount             Decimal?                   @db.Decimal(12, 2)
  totalAmount           Decimal?                   @db.Decimal(12, 2)
  rawPayload            Json
  fetchedAt             DateTime                   @default(now())

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  syncRun          MyDataSyncRun    @relation(fields: [syncRunId], references: [id])
  matchedDocument  Document?        @relation("MyDataSnapshotMatchedDocument", fields: [matchedDocumentId], references: [id])
  reviewedBy       User?            @relation("MyDataSnapshotReviewedBy", fields: [reviewedById], references: [id])

  @@unique([clientCompanyId, source, mark])
  @@index([accountingOfficeId, clientCompanyId, reconciliationStatus], map: "MyDataSnapshot_office_client_status_idx")
  @@index([clientCompanyId, issueDate], map: "MyDataSnapshot_client_issue_idx")
  @@index([matchedDocumentId], map: "MyDataSnapshot_matched_doc_idx")
  @@index([accountingOfficeId, reviewStatus, fetchedAt], map: "MyDataSnapshot_office_review_fetched_idx")
  @@index([reviewedById], map: "MyDataSnapshot_reviewed_by_idx")
}

