generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ACCOUNTING_OFFICE_ADMIN
  ACCOUNTANT
  ASSISTANT
  CLIENT_READONLY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum DocumentType {
  SALES_INVOICE
  PURCHASE_INVOICE
  CREDIT_NOTE
  RETAIL_RECEIPT
}

enum MyDataStatus {
  DRAFT
  READY_TO_SEND
  SENT
  FAILED
  CANCELLED
}

enum TransmissionStatus {
  PREPARED
  SENT
  FAILED
}

enum ClientEntityType {
  COMPANY
  FREELANCER
  SOLE_PROPRIETOR
  NON_PROFIT
  OTHER
}

enum MyDataTransmissionMode {
  ACCOUNTING_OFFICE_AUTHORIZED
  OWN_API_CREDENTIALS_ENV_REF
  MANUAL_UPLOAD
  NOT_CONFIGURED
}

enum ObligationType {
  VAT_RETURN
  MYDATA_REVIEW
  WITHHOLDING_TAX
  INCOME_TAX_PREP
  PAYROLL_REVIEW
  CUSTOM
}

enum ObligationStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  READY_TO_SUBMIT
  SUBMITTED
  CANCELLED
}

enum ObligationRecurrence {
  NONE
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum FixedAssetCategory {
  EQUIPMENT
  SOFTWARE
  VEHICLE
  FURNITURE
  BUILDING
  OTHER
}

enum FixedAssetStatus {
  ACTIVE
  SOLD
  SCRAPPED
}

enum CounterpartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum ImportBatchType {
  DOCUMENTS_CSV
}

enum ImportBatchStatus {
  PREVIEW
  COMPLETED
  FAILED
}

enum DeclarationWorkpaperType {
  VAT_RETURN
  MYDATA_RECONCILIATION
  WITHHOLDING_TAX
  INCOME_TAX_PREP
  PAYROLL_REVIEW
}

enum DeclarationWorkpaperStatus {
  DRAFT
  READY
  APPROVED
  SUBMITTED
  ARCHIVED
}

enum PeriodCloseKind {
  MONTHLY
  QUARTERLY
}

enum PeriodCloseReviewStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  REJECTED
}

enum ChartAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalEntrySource {
  MANUAL
  DOCUMENT
  FIXED_ASSET
  OPENING
  CLOSING
  ADJUSTMENT
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum MyDataSyncSource {
  REQUEST_DOCS
  REQUEST_TRANSMITTED_DOCS
}

enum MyDataSyncRunStatus {
  COMPLETED
  FAILED
}

enum MyDataReconciliationStatus {
  MATCHED
  MISSING_INTERNAL
  AMOUNT_MISMATCH
  DATE_MISMATCH
  TYPE_MISMATCH
  COUNTERPARTY_MISMATCH
}

model AccountingOffice {
  id        String   @id @default(cuid())
  name      String
  vatNumber String?  @db.VarChar(9)
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  clientCompanies       ClientCompany[]
  documents             Document[]
  fixedAssets           FixedAsset[]
  clientSetupItems      ClientSetupItem[]
  obligations           OfficeObligation[]
  counterparties        Counterparty[]
  importBatches         ImportBatch[]
  declarationWorkpapers DeclarationWorkpaper[]
  chartAccounts         ChartAccount[]
  documentPostingRules  DocumentPostingRule[]
  accountingPeriods     AccountingPeriod[]
  journalEntries        JournalEntry[]
  auditLogs             AuditLog[]
  myDataSyncRuns        MyDataSyncRun[]
  myDataSnapshots       MyDataSnapshot[]
  periodCloseReviews    PeriodCloseReview[]
}

model User {
  id                  String    @id @default(cuid())
  accountingOfficeId  String
  email               String    @unique
  passwordHash        String
  fullName            String
  role                UserRole
  disabledAt          DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  passwordChangedAt   DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accountingOffice              AccountingOffice       @relation(fields: [accountingOfficeId], references: [id])
  auditLogs                     AuditLog[]
  assignedObligations           OfficeObligation[]     @relation("AssignedObligations")
  refreshTokens                 RefreshToken[]
  passwordResetTokens           PasswordResetToken[]
  preparedPeriodCloseReviews    PeriodCloseReview[]    @relation("PeriodClosePreparedBy")
  approvedPeriodCloseReviews    PeriodCloseReview[]    @relation("PeriodCloseApprovedBy")
  approvedDeclarationWorkpapers DeclarationWorkpaper[] @relation("DeclarationWorkpaperApprovedBy")

  @@index([accountingOfficeId])
  @@index([disabledAt])
  @@index([lockedUntil])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  jwtId             String    @unique @db.VarChar(80)
  tokenHash         String    @unique @db.VarChar(128)
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique @db.VarChar(128)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, usedAt, expiresAt])
}

model ClientCompany {
  id                  String                 @id @default(cuid())
  accountingOfficeId  String
  legalName           String
  tradeName           String?
  entityType          ClientEntityType       @default(COMPANY)
  professionLabel     String?
  vatNumber           String                 @db.VarChar(9)
  taxOffice           String?
  activityCodes       Json?
  address             String?
  email               String?
  phone               String?
  vatRegime           String?
  accountingCategory  String?
  myDataMode          MyDataTransmissionMode @default(ACCOUNTING_OFFICE_AUTHORIZED)
  myDataAuthorized    Boolean                @default(false)
  myDataCredentialRef String?
  fiscalYearStart     Int                    @default(1)
  fiscalYearEnd       Int                    @default(12)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  deletedAt           DateTime?

  accountingOffice      AccountingOffice       @relation(fields: [accountingOfficeId], references: [id])
  documents             Document[]
  fixedAssets           FixedAsset[]
  setupItems            ClientSetupItem[]
  obligations           OfficeObligation[]
  counterparties        Counterparty[]
  importBatches         ImportBatch[]
  declarationWorkpapers DeclarationWorkpaper[]
  chartAccounts         ChartAccount[]
  documentPostingRules  DocumentPostingRule[]
  accountingPeriods     AccountingPeriod[]
  journalEntries        JournalEntry[]
  myDataSyncRuns        MyDataSyncRun[]
  myDataSnapshots       MyDataSnapshot[]
  periodCloseReviews    PeriodCloseReview[]

  @@unique([accountingOfficeId, vatNumber])
  @@index([accountingOfficeId, deletedAt])
}

model ChartAccount {
  id                 String           @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  code               String           @db.VarChar(40)
  name               String
  type               ChartAccountType
  normalBalance      NormalBalance
  parentId           String?
  isControl          Boolean          @default(false)
  isActive           Boolean          @default(true)
  taxCategory        String?          @db.VarChar(80)
  myDataCategory     String?          @db.VarChar(80)
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  accountingOffice AccountingOffice   @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany      @relation(fields: [clientCompanyId], references: [id])
  parent           ChartAccount?      @relation("ChartAccountTree", fields: [parentId], references: [id])
  children         ChartAccount[]     @relation("ChartAccountTree")
  journalLines     JournalEntryLine[]

  @@unique([clientCompanyId, code])
  @@index([accountingOfficeId, clientCompanyId, type])
  @@index([parentId])
}

model DocumentPostingRule {
  id                      String         @id @default(cuid())
  accountingOfficeId      String
  clientCompanyId         String
  code                    String         @db.VarChar(80)
  name                    String
  documentType            DocumentType?
  movementCode            String?        @db.VarChar(80)
  journalCode             String?        @db.VarChar(80)
  counterpartyAccountCode String         @db.VarChar(40)
  counterpartySide        NormalBalance
  netAccountCode          String         @db.VarChar(40)
  netSide                 NormalBalance
  vatAccountCode          String?        @db.VarChar(40)
  vatSide                 NormalBalance?
  isActive                Boolean        @default(true)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])

  @@unique([clientCompanyId, code], map: "DocPostingRule_client_code_key")
  @@index([accountingOfficeId, clientCompanyId, isActive], map: "DocPostingRule_office_client_active_idx")
  @@index([clientCompanyId, movementCode], map: "DocPostingRule_client_movement_idx")
  @@index([clientCompanyId, documentType], map: "DocPostingRule_client_doc_type_idx")
}

model AccountingPeriod {
  id                 String                 @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  fiscalYear         Int
  periodMonth        Int
  startsAt           DateTime
  endsAt             DateTime
  status             AccountingPeriodStatus @default(OPEN)
  closedAt           DateTime?
  lockedAt           DateTime?
  notes              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])

  @@unique([clientCompanyId, fiscalYear, periodMonth])
  @@index([accountingOfficeId, clientCompanyId, status])
}

model JournalEntry {
  id                 String             @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  entryNumber        String             @db.VarChar(80)
  entryDate          DateTime
  fiscalYear         Int
  periodMonth        Int
  source             JournalEntrySource
  status             JournalEntryStatus @default(POSTED)
  description        String
  reference          String?
  postedAt           DateTime?
  voidedAt           DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  accountingOffice  AccountingOffice                       @relation(fields: [accountingOfficeId], references: [id])
  clientCompany     ClientCompany                          @relation(fields: [clientCompanyId], references: [id])
  lines             JournalEntryLine[]
  documentLinks     DocumentAccountingLink[]
  depreciationLinks FixedAssetDepreciationAccountingLink[]

  @@unique([clientCompanyId, entryNumber])
  @@index([accountingOfficeId, clientCompanyId, entryDate])
  @@index([clientCompanyId, fiscalYear, periodMonth, status])
}

model JournalEntryLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  lineNumber     Int
  description    String?
  debit          Decimal  @default(0) @db.Decimal(12, 2)
  credit         Decimal  @default(0) @db.Decimal(12, 2)
  taxCode        String?  @db.VarChar(40)
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])
  account      ChartAccount @relation(fields: [accountId], references: [id])

  @@unique([journalEntryId, lineNumber])
  @@index([accountId])
}

model DocumentAccountingLink {
  id             String   @id @default(cuid())
  documentId     String
  journalEntryId String
  createdAt      DateTime @default(now())

  document     Document     @relation(fields: [documentId], references: [id])
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])

  @@unique([documentId])
  @@unique([journalEntryId])
}

model ClientSetupItem {
  id                 String   @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  kind               String   @db.VarChar(80)
  code               String   @db.VarChar(80)
  name               String
  description        String?
  metadata           Json?
  sourceTemplate     String?  @db.VarChar(80)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])

  @@unique([clientCompanyId, kind, code], map: "ClientSetupItem_client_kind_code_key")
  @@index([accountingOfficeId, clientCompanyId, kind], map: "ClientSetupItem_office_client_kind_idx")
}

model Counterparty {
  id                 String           @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  type               CounterpartyType
  name               String
  vatNumber          String?          @db.VarChar(20)
  country            String           @default("GR") @db.VarChar(2)
  taxOffice          String?
  address            String?
  email              String?
  phone              String?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])

  @@index([accountingOfficeId, clientCompanyId, type])
  @@index([clientCompanyId, vatNumber])
}

model ImportBatch {
  id                 String            @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  type               ImportBatchType
  status             ImportBatchStatus
  fileName           String?
  totalRows          Int               @default(0)
  successfulRows     Int               @default(0)
  failedRows         Int               @default(0)
  errorReport        Json?
  createdAt          DateTime          @default(now())

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])

  @@index([accountingOfficeId, createdAt])
  @@index([clientCompanyId, createdAt])
}

model DeclarationWorkpaper {
  id                 String                     @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  type               DeclarationWorkpaperType
  title              String
  periodYear         Int
  periodMonth        Int?
  status             DeclarationWorkpaperStatus @default(DRAFT)
  totals             Json
  notes              String?
  generatedAt        DateTime                   @default(now())
  submittedAt        DateTime?
  approvedById       String?
  approvedAt         DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  approvedBy       User?            @relation("DeclarationWorkpaperApprovedBy", fields: [approvedById], references: [id])

  @@unique([clientCompanyId, type, periodYear, periodMonth], map: "DeclWorkpaper_period_key")
  @@index([accountingOfficeId, type, status], map: "DeclWorkpaper_office_type_status_idx")
  @@index([clientCompanyId, periodYear, periodMonth], map: "DeclWorkpaper_client_period_idx")
  @@index([approvedById], map: "DeclWorkpaper_approved_by_idx")
}

model PeriodCloseReview {
  id                 String                  @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  kind               PeriodCloseKind
  periodYear         Int
  startMonth         Int
  endMonth           Int
  status             PeriodCloseReviewStatus @default(DRAFT)
  checklist          Json
  reviewSummary      Json
  notes              String?
  rejectionReason    String?
  preparedById       String?
  approvedById       String?
  preparedAt         DateTime?
  submittedAt        DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  preparedBy       User?            @relation("PeriodClosePreparedBy", fields: [preparedById], references: [id])
  approvedBy       User?            @relation("PeriodCloseApprovedBy", fields: [approvedById], references: [id])

  @@unique([clientCompanyId, kind, periodYear, endMonth], map: "PeriodCloseReview_period_key")
  @@index([accountingOfficeId, status, periodYear], map: "PeriodCloseReview_office_status_year_idx")
  @@index([clientCompanyId, periodYear, startMonth, endMonth], map: "PeriodCloseReview_client_period_idx")
  @@index([preparedById], map: "PeriodCloseReview_prepared_by_idx")
  @@index([approvedById], map: "PeriodCloseReview_approved_by_idx")
}

model FixedAsset {
  id                        String             @id @default(cuid())
  accountingOfficeId        String
  clientCompanyId           String
  code                      String
  description               String
  category                  FixedAssetCategory @default(OTHER)
  acquisitionDate           DateTime
  depreciationStartDate     DateTime
  acquisitionDocumentNumber String?
  supplierName              String?
  netValue                  Decimal            @db.Decimal(12, 2)
  vatAmount                 Decimal            @db.Decimal(12, 2)
  totalValue                Decimal            @db.Decimal(12, 2)
  depreciationRate          Decimal            @db.Decimal(5, 2)
  accumulatedDepreciation   Decimal            @default(0) @db.Decimal(12, 2)
  status                    FixedAssetStatus   @default(ACTIVE)
  disposalDate              DateTime?
  notes                     String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  accountingOffice    AccountingOffice              @relation(fields: [accountingOfficeId], references: [id])
  clientCompany       ClientCompany                 @relation(fields: [clientCompanyId], references: [id])
  depreciationEntries FixedAssetDepreciationEntry[]

  @@unique([clientCompanyId, code])
  @@index([accountingOfficeId, clientCompanyId, status])
}

model FixedAssetDepreciationEntry {
  id                String   @id @default(cuid())
  fixedAssetId      String
  fiscalYear        Int
  amount            Decimal  @db.Decimal(12, 2)
  accumulatedAmount Decimal  @db.Decimal(12, 2)
  bookValueAfter    Decimal  @db.Decimal(12, 2)
  posted            Boolean  @default(false)
  createdAt         DateTime @default(now())

  fixedAsset      FixedAsset                             @relation(fields: [fixedAssetId], references: [id])
  accountingLinks FixedAssetDepreciationAccountingLink[]

  @@unique([fixedAssetId, fiscalYear])
  @@index([fixedAssetId, fiscalYear])
}

model FixedAssetDepreciationAccountingLink {
  id                  String   @id @default(cuid())
  depreciationEntryId String
  journalEntryId      String
  createdAt           DateTime @default(now())

  depreciationEntry FixedAssetDepreciationEntry @relation(fields: [depreciationEntryId], references: [id])
  journalEntry      JournalEntry                @relation(fields: [journalEntryId], references: [id])

  @@unique([depreciationEntryId], map: "DepAcctLink_depreciation_key")
  @@unique([journalEntryId], map: "DepAcctLink_journal_key")
}

model OfficeObligation {
  id                 String               @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  assignedUserId     String?
  type               ObligationType
  title              String
  periodYear         Int
  periodMonth        Int?
  dueDate            DateTime
  status             ObligationStatus     @default(OPEN)
  recurrence         ObligationRecurrence @default(NONE)
  notes              String?
  completedAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  assignedUser     User?            @relation("AssignedObligations", fields: [assignedUserId], references: [id])

  @@unique([clientCompanyId, type, periodYear, periodMonth])
  @@index([accountingOfficeId, status, dueDate])
  @@index([clientCompanyId, dueDate])
  @@index([assignedUserId])
}

model Document {
  id                       String       @id @default(cuid())
  accountingOfficeId       String
  clientCompanyId          String
  documentType             DocumentType
  series                   String?
  documentNumber           String
  issueDate                DateTime
  counterpartyName         String?
  counterpartyVatNumber    String?      @db.VarChar(20)
  movementCode             String?      @db.VarChar(80)
  journalCode              String?      @db.VarChar(80)
  netAmount                Decimal      @db.Decimal(12, 2)
  vatAmount                Decimal      @db.Decimal(12, 2)
  totalAmount              Decimal      @db.Decimal(12, 2)
  vatCategory              String
  paymentMethodType        Int          @default(3)
  vatExemptionCategory     Int?
  correlatedInvoiceMark    String?      @db.VarChar(40)
  withheldAmount           Decimal      @default(0) @db.Decimal(12, 2)
  withheldCategory         Int?
  feesAmount               Decimal      @default(0) @db.Decimal(12, 2)
  feesCategory             Int?
  stampDutyAmount          Decimal      @default(0) @db.Decimal(12, 2)
  stampDutyCategory        Int?
  otherTaxesAmount         Decimal      @default(0) @db.Decimal(12, 2)
  otherTaxesCategory       Int?
  deductionsAmount         Decimal      @default(0) @db.Decimal(12, 2)
  myDataStatus             MyDataStatus @default(DRAFT)
  myDataMark               String?
  myDataUid                String?
  myDataQrUrl              String?
  myDataClassificationMark String?      @db.VarChar(40)
  myDataCancellationMark   String?      @db.VarChar(40)
  myDataCancelledAt        DateTime?
  myDataXmlPreview         String?      @db.LongText
  classificationStatus     String?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  deletedAt                DateTime?

  accountingOffice      AccountingOffice         @relation(fields: [accountingOfficeId], references: [id])
  clientCompany         ClientCompany            @relation(fields: [clientCompanyId], references: [id])
  transmissionAttempts  TransmissionAttempt[]
  accountingLinks       DocumentAccountingLink[]
  myDataSnapshotMatches MyDataSnapshot[]         @relation("MyDataSnapshotMatchedDocument")

  @@index([accountingOfficeId, clientCompanyId, issueDate])
  @@index([accountingOfficeId, myDataStatus])
  @@index([myDataClassificationMark])
  @@index([myDataCancellationMark])
  @@index([clientCompanyId, movementCode, issueDate])
  @@index([clientCompanyId, journalCode, issueDate])
}

model MyDataSyncRun {
  id                 String              @id @default(cuid())
  accountingOfficeId String
  clientCompanyId    String
  source             MyDataSyncSource
  status             MyDataSyncRunStatus
  environment        String?             @db.VarChar(40)
  endpoint           String?             @db.VarChar(255)
  markFrom           String?             @db.VarChar(40)
  maxMark            String?             @db.VarChar(40)
  dateFrom           DateTime?
  dateTo             DateTime?
  fetchedCount       Int                 @default(0)
  matchedCount       Int                 @default(0)
  mismatchCount      Int                 @default(0)
  errorMessage       String?
  rawResponse        Json?
  createdAt          DateTime            @default(now())

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  snapshots        MyDataSnapshot[]

  @@index([accountingOfficeId, clientCompanyId, createdAt], map: "MyDataSyncRun_office_client_created_idx")
  @@index([source, status, createdAt], map: "MyDataSyncRun_source_status_created_idx")
}

model MyDataSnapshot {
  id                    String                     @id @default(cuid())
  accountingOfficeId    String
  clientCompanyId       String
  syncRunId             String
  matchedDocumentId     String?
  source                MyDataSyncSource
  reconciliationStatus  MyDataReconciliationStatus
  reconciliationIssues  Json?
  mark                  String                     @db.VarChar(40)
  uid                   String?                    @db.VarChar(120)
  qrUrl                 String?
  issuerVatNumber       String?                    @db.VarChar(20)
  counterpartyVatNumber String?                    @db.VarChar(20)
  invoiceType           String?                    @db.VarChar(20)
  series                String?                    @db.VarChar(80)
  documentNumber        String                     @db.VarChar(80)
  issueDate             DateTime?
  netAmount             Decimal?                   @db.Decimal(12, 2)
  vatAmount             Decimal?                   @db.Decimal(12, 2)
  totalAmount           Decimal?                   @db.Decimal(12, 2)
  rawPayload            Json
  fetchedAt             DateTime                   @default(now())

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id])
  syncRun          MyDataSyncRun    @relation(fields: [syncRunId], references: [id])
  matchedDocument  Document?        @relation("MyDataSnapshotMatchedDocument", fields: [matchedDocumentId], references: [id])

  @@unique([clientCompanyId, source, mark])
  @@index([accountingOfficeId, clientCompanyId, reconciliationStatus], map: "MyDataSnapshot_office_client_status_idx")
  @@index([clientCompanyId, issueDate], map: "MyDataSnapshot_client_issue_idx")
  @@index([matchedDocumentId], map: "MyDataSnapshot_matched_doc_idx")
}

model TransmissionAttempt {
  id              String             @id @default(cuid())
  documentId      String
  provider        String
  environment     String?            @db.VarChar(40)
  endpoint        String?            @db.VarChar(255)
  correlationId   String?            @db.VarChar(80)
  forcedRetry     Boolean            @default(false)
  status          TransmissionStatus
  requestPayload  String             @db.LongText
  responsePayload Json?
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime           @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@index([documentId, createdAt])
  @@index([provider, environment, createdAt])
  @@index([correlationId])
}

model AuditLog {
  id                 String      @id @default(cuid())
  accountingOfficeId String
  userId             String?
  action             AuditAction
  entityType         String
  entityId           String
  oldValue           Json?
  newValue           Json?
  createdAt          DateTime    @default(now())

  accountingOffice AccountingOffice @relation(fields: [accountingOfficeId], references: [id])
  user             User?            @relation(fields: [userId], references: [id])

  @@index([accountingOfficeId, entityType, entityId])
  @@index([userId])
}
