{
  "name": "@open-logistirio/api",
  "version": "0.2.0-rc.5",
  "private": true,
  "description": "Open Logistirio API",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "dotenv -e ../../.env -- nest start --watch",
    "build": "nest build",
    "start": "dotenv -e ../../.env -- node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:generate:production": "prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:deploy:production": "prisma migrate deploy",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "bootstrap:production": "tsx prisma/bootstrap-production.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "3.0.3",
    "bullmq": "5.79.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "fast-xml-parser": "^5.9.3",
    "helmet": "8.2.0",
    "ioredis": "5.11.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "swagger-ui-express": "5.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@types/bcryptjs": "3.0.0",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "26.1.0",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "7.2.0",
    "dotenv-cli": "^11.0.0",
    "jest": "30.4.2",
    "prisma": "^6.19.0",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "tsx": "4.23.0",
    "typescript": "6.0.3"
  }
}
