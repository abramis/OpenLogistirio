NODE_ENV=development

MYSQL_DATABASE=open_logistirio
MYSQL_USER=openlog
MYSQL_PASSWORD=openlog_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_HOST_PORT=3307
REDIS_HOST_PORT=6380

# Local development values. Docker Compose overrides these internally to use
# service hostnames `mysql` and `redis`.
DATABASE_URL=mysql://openlog:openlog_password@localhost:3306/open_logistirio
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

API_PORT=3000
WEB_PORT=4200
FRONTEND_ORIGIN=http://localhost:4200
BACKUP_DIR=./backups
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
TRUST_PROXY=false

# AADE myDATA test-environment credentials.
# Create these from the official myDATA REST API test registration flow.
# Never put TAXISnet passwords here.
AADE_MYDATA_ENV=test
# Enables only GET RequestDocs/RequestTransmittedDocs in production.
AADE_MYDATA_PRODUCTION_READ_ENABLED=false
# Enables SendInvoices, classifications and cancellations in production.
AADE_MYDATA_PRODUCTION_ENABLED=false
AADE_MYDATA_USER_ID=
AADE_MYDATA_SUBSCRIPTION_KEY=
AADE_MYDATA_TIMEOUT_MS=15000
MYDATA_SCHEDULED_SYNC_ENABLED=false
MYDATA_SCHEDULED_SYNC_CRON=0 2 * * *
MYDATA_SCHEDULED_SYNC_MAX_PAGES=10
AADE_MYDATA_TEST_SEND_INVOICES_URL=https://mydataapidev.aade.gr/SendInvoices
AADE_MYDATA_TEST_SEND_EXPENSES_CLASSIFICATION_URL=https://mydataapidev.aade.gr/SendExpensesClassification
AADE_MYDATA_TEST_CANCEL_INVOICE_URL=https://mydataapidev.aade.gr/CancelInvoice
AADE_MYDATA_TEST_REQUEST_DOCS_URL=https://mydataapidev.aade.gr/RequestDocs
AADE_MYDATA_TEST_REQUEST_TRANSMITTED_DOCS_URL=https://mydataapidev.aade.gr/RequestTransmittedDocs
AADE_MYDATA_PRODUCTION_SEND_INVOICES_URL=https://mydatapi.aade.gr/myDATA/SendInvoices
AADE_MYDATA_PRODUCTION_SEND_EXPENSES_CLASSIFICATION_URL=https://mydatapi.aade.gr/myDATA/SendExpensesClassification
AADE_MYDATA_PRODUCTION_CANCEL_INVOICE_URL=https://mydatapi.aade.gr/myDATA/CancelInvoice
AADE_MYDATA_PRODUCTION_REQUEST_DOCS_URL=https://mydatapi.aade.gr/myDATA/RequestDocs
AADE_MYDATA_PRODUCTION_REQUEST_TRANSMITTED_DOCS_URL=https://mydatapi.aade.gr/myDATA/RequestTransmittedDocs

# Optional per-client AADE credentials. Use this only when a client should send
# with their own myDATA REST API user instead of the accounting office user.
# In the client form set Env reference credentials to CLIENT_111222333, then set:
# AADE_MYDATA_CLIENT_111222333_USER_ID=
# AADE_MYDATA_CLIENT_111222333_SUBSCRIPTION_KEY=

# AADE Business Registry basic-details lookup.
# These are special credentials from "Διαχείριση Ειδικών Κωδικών" for
# "Αναζήτηση Βασικών Στοιχείων Μητρώου Επιχειρήσεων", not myDATA keys.
AADE_REGISTRY_USERNAME=
AADE_REGISTRY_PASSWORD=
AADE_REGISTRY_CALLED_BY_VAT=
AADE_REGISTRY_ENDPOINT=https://www1.gsis.gr/wsaade/RgWsPublic2/RgWsPublic2
